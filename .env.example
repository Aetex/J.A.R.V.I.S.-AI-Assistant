# J.A.R.V.I.S. Environment Configuration
# Get your API keys at:
# Groq: https://console.groq.com/keys
# Gemini: https://aistudio.google.com/app/apikey

# Default priority: Groq > Gemini > llama.cpp
# You can customize this order by changing the provider priority below
GROQ_API_KEY="PASTE_YOUR_GROQ_KEY_HERE"
GOOGLE_API_KEY="PASTE_YOUR_GEMINI_KEY_HERE"

# Local Model Configuration (llama.cpp)
# Set to true to use local models instead of cloud APIs
LLAMA_CPP_ENABLED="false"
# Path to the downloaded .gguf model file (relative to project root)
LLAMA_CPP_MODEL_PATH="models/your-model.gguf"

# AI Provider Priority (comma-separated, in order of preference)
# Options: groq, gemini, llama_cpp
# Default: groq,gemini,llama_cpp
AI_PROVIDER_PRIORITY="groq,gemini,llama_cpp"

# Optional: Add any other configuration variables here
# DEBUG_MODE="True"
